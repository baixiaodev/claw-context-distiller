{
  "name": "context-distiller",
  "version": "0.1.0",
  "description": "Intelligent context distillation plugin for OpenClaw — reduces context noise by compressing verbose tool outputs, patches, and file content before LCM ingestion. Saves 65-85% tokens on average.",
  "type": "module",
  "main": "index.ts",
  "license": "MIT",
  "author": "Yuan",
  "repository": {
    "type": "git",
    "url": "https://github.com/baixiaodev/context-distiller.git"
  },
  "homepage": "https://github.com/baixiaodev/context-distiller#readme",
  "bugs": {
    "url": "https://github.com/baixiaodev/context-distiller/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "context-distiller",
    "context-compression",
    "token-optimization",
    "llm",
    "ai-agent",
    "context-window"
  ],
  "files": [
    "index.ts",
    "src/**/*.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
